{
  "expo": {
    "name": "Whispr_Frontend",
    "slug": "Whispr_Frontend",
    "scheme": "whispr",
    "version": "1.0.0",
    "extra": {
      "apiBaseUrl": "https://whispr-preprod.roadmvn.com",
      "devAuthApiUrl": "http://10.0.2.2:3010",
      "devUserApiUrl": "http://10.0.2.2:3011",
      "legalPrivacyUrl": "https://whispr.example/privacy",
      "legalTermsUrl": "https://whispr.example/terms",
      "appVersion": "1.0.0",
      "eas": {
        "projectId": "203ca2cd-9035-489b-9c0d-ca4a1bfb2d36"
      }
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.Whispr-Frontend",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        },
        "NSMicrophoneUsageDescription": "Whispr a besoin du micro pour les appels voix et video.",
        "NSCameraUsageDescription": "Whispr a besoin de la camera pour les appels video.",
        "UIBackgroundModes": ["voip", "audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "whispr.test1702",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "MODIFY_AUDIO_SETTINGS",
        "INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Whispr utilise la caméra pour scanner les QR codes et ajouter des contacts."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff"
        }
      ]
    ]
  }
}
